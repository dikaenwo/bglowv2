# ─── B-Glow Backend Environment Variables ───
# Copy file ini ke `.env` dan isi dengan nilai yang sesuai
# JANGAN commit file .env ke Git!

# JWT Secret Key — gunakan string panjang dan random di production
# Buat dengan: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=ganti-dengan-secret-key-yang-panjang-dan-random

# Database MySQL
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=ganti-dengan-password-database-kamu
DB_NAME=bglow_db

# Allowed CORS Origins (pisahkan dengan koma jika lebih dari satu)
# Contoh: http://localhost:5173,https://bglow.app
CORS_ORIGINS=*
